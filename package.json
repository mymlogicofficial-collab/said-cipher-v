{
  "name": "said-cipher",
  "version": "1.0.0",
  "description": "S.A.I.D. Cipher — MYM Logic LLC",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win",
    "rebuild": "electron-rebuild -f -w node-pty,better-sqlite3",
    "postinstall": "electron-rebuild -f -w node-pty,better-sqlite3"
  },
  "build": {
    "appId": "com.mymlogic.said-cipher",
    "productName": "S.A.I.D. Cipher",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "files": [
      "**/*",
      "!node_modules/.cache"
    ]
  },
  "dependencies": {
    "ace-builds": "^1.32.0",
    "better-sqlite3": "^9.4.3",
    "chart.js": "^4.4.2",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "node-pty": "^1.0.0",
    "openai": "^4.28.0",
    "uuid": "^9.0.0",
    "ws": "^8.16.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "form-data": "^4.0.0"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.9.1",
    "electron-rebuild": "^3.2.9"
  },
  "allowScripts": {
    "better-sqlite3@9.6.0": true,
    "electron@29.4.6": true,
    "lzma-native@8.0.6": true,
    "node-pty@1.1.0": true
  }
}
