{
  "name": "said-cipher",
  "version": "1.0.0",
  "description": "MYM Logic LLC - S.A.I.D. (Cipher) Desktop Application",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win --x64",
    "build:portable": "electron-builder --win portable --x64"
  },
  "author": "MYM Logic LLC",
  "license": "PROPRIETARY",
  "build": {
    "appId": "com.mymlogic.said",
    "productName": "S.A.I.D. Cipher",
    "copyright": "Copyright © 2025 MYM Logic LLC",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "package.json",
      "server/**/*",
      "src/**/*",
      "core/**/*",
      "node_modules/**/*",
      "!node_modules/electron/**",
      "!node_modules/electron-builder/**",
      "!dist/**",
      "!uploads/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerHeaderIcon": "build/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "S.A.I.D. Cipher"
    },
    "portable": {
      "artifactName": "SAID-Cipher-${version}-portable.exe"
    }
  },
  "dependencies": {
    "ace-builds": "^1.43.6",
    "chart.js": "^4.5.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "drizzle-zod": "^0.8.3",
    "express": "^5.2.1",
    "firebase": "^12.10.0",
    "firebase-admin": "^13.7.0",
    "marked": "^17.0.4",
    "multer": "^2.1.1",
    "node-pty": "^1.1.0",
    "openai": "^6.25.0",
    "p-limit": "^7.3.0",
    "p-retry": "^7.1.1",
    "ws": "^8.19.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "zod": "^4.3.6",
    "zod-validation-error": "^5.0.0"
  },
  "devDependencies": {
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1"
  }
}
